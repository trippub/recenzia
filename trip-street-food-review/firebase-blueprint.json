{
  "entities": {
    "Review": {
      "title": "Review",
      "description": "A customer review/feedback entry.",
      "type": "object",
      "properties": {
        "rating": {
          "type": "integer",
          "description": "Main star rating (1-5)."
        },
        "food": {
          "type": "integer",
          "description": "Rating for food (1-5)."
        },
        "service": {
          "type": "integer",
          "description": "Rating for service (1-5)."
        },
        "atmosphere": {
          "type": "integer",
          "description": "Rating for atmosphere (1-5)."
        },
        "message": {
          "type": "string",
          "description": "The detailed feedback message."
        },
        "contact": {
          "type": "string",
          "description": "Customer contact info (optional)."
        },
        "photos": {
          "type": "array",
          "items": { "type": "string" },
          "description": "URLs of uploaded photos."
        },
        "ip": {
          "type": "string",
          "description": "The IP address of the submitter."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of submission."
        }
      },
      "required": ["rating", "message", "createdAt"]
    }
  },
  "firestore": {
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Collection of customer reviews."
    }
  }
}
